   "source": [
    "!pip install yfinance\n",
    "import yfinance as yf\n",
    "import json\n",
    "import time\n",
    "\n",
    "stock = \"RELIANCE.NS\"\n",
    "\n",
    "ticker = yf.Ticker(stock)\n",
    "\n",
    "df = ticker.history(\n",
    "                period=\"1d\",\n",
    "                interval=\"1m\"\n",
    "            )\n",
    "\n",
    "latest = df.iloc[-1]\n",
    "print(latest)"
   ]
